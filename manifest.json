{
  "name": "IdeaJar",
  "description": "A sleek and fast vault for your prompts, snippets, and notes. Capture text directly from any webpage and instantly inject your best ideas back into them.",
  "version": "1.0.0",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "IdeaJar@eclipse.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "background/background.js"
    ],
    "type": "module"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icons/logo128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/logo16.png",
    "32": "assets/icons/logo32.png",
    "48": "assets/icons/logo48.png",
    "128": "assets/icons/logo128.png"
  }
}