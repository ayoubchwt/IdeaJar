{
  "name": "IdeaJar",
  "description": "IdeaJar is a simple browser extension for collecting and organizing your AI ideas. Save useful prompts, snippets, and instructions while you browse, and keep them ready for whenever you need them.",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": ["storage", "contextMenus"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icons/logo128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"]
    }
  ],
  "icons": {
    "16": "assets/icons/logo16.png",
    "32": "assets/icons/logo32.png",
    "48": "assets/icons/logo48.png",
    "128": "assets/icons/logo128.png"
  }
}
